{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "noEmit": true,
    "allowJs": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@pulse/contracts": ["../../packages/contracts/src"],
      "@pulse/theme": ["../../packages/theme/src"]
    }
  },
  "include": ["app", "next-env.d.ts", ".next/types/**/*.ts"]
}
