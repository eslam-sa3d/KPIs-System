# Copy to .env.local for local dev. Next.js only inlines NEXT_PUBLIC_* vars
# into the client bundle — anything without that prefix is never sent to the
# browser and won't do anything here.

# Where the app fetches the API from. Defaults to http://localhost:4000 if unset.
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Only set for a GitHub Pages project-page deploy (served from
# https://<user>.github.io/<repo>/, not the domain root) — see next.config.mjs.
# Leave unset for local dev and for Render, which serves from the domain root.
NEXT_PUBLIC_BASE_PATH=

# Cloudflare Turnstile site key for the public form-fill CAPTCHA widget
# (apps/web/app/f/page.tsx). Pairs with TURNSTILE_SECRET_KEY on the API —
# leave both unset to skip CAPTCHA entirely in dev.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
