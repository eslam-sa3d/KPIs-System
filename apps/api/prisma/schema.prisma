// pulse KPI System — core data model
// Postgres 16. JSONB powers the schema-driven Form Builder + flexible KPI metadata.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Identity & Dynamic RBAC ───────────────────────────

model User {
  id                 String      @id @default(uuid())
  email              String      @unique
  passwordHash       String
  displayName        String
  departmentId       String?
  department         Department? @relation(fields: [departmentId], references: [id])
  jobTitleId         String?
  jobTitle           JobTitle?   @relation(fields: [jobTitleId], references: [id])
  isActive           Boolean     @default(true)
  /// Whether this person should be scored/tracked by the KPI system at all —
  /// set at creation, editable after. When false, they're excluded from the
  /// dashboard's team overview regardless of role/department KPI mappings.
  isKpiApplicable    Boolean     @default(true)
  /// Set true whenever an admin issues this account's password (creation
  /// today — see UsersService.create) so the next login forces a change
  /// before anything else is usable. Cleared by AuthService.changePassword.
  mustChangePassword Boolean     @default(false)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  roles                   UserRole[]
  sessions                Session[]
  passwordResetTokens     PasswordResetToken[]
  submissions             FormSubmission[]
  evaluatedEntries        EvaluationAreaEntry[] @relation("EvaluationAreaEntryPerson")
  recordedEntries         EvaluationAreaEntry[] @relation("EvaluationAreaEntryEvaluator")
  auditEvents             AuditLog[]
  fileUploads             FormFileUpload[]
  formAssets              FormAsset[]
  formCollaborations      FormCollaborator[]    @relation("FormCollaboratorUser")
  formCollaboratorInvites FormCollaborator[]    @relation("FormCollaboratorAddedBy")
  projectGroupMemberships ProjectGroupMember[]

  @@index([departmentId])
  @@index([jobTitleId])
}

model Department {
  id      String          @id @default(uuid())
  name    String          @unique
  users   User[]
  kpiMaps KpiAssignment[]
}

/// Parallel grouping to Department — independent of it, and unlike
/// Department a user may belong to several project groups at once (e.g.
/// staffed on multiple projects), so membership is a join table rather than
/// a single FK on User.
model ProjectGroup {
  id      String               @id @default(uuid())
  name    String               @unique
  members ProjectGroupMember[]
}

/// Join table for ProjectGroup <-> User membership. A row's existence IS the
/// membership; changes are audited separately via AuditLog
/// (project_group.member_added/member_removed) rather than tracked here.
model ProjectGroupMember {
  userId    String
  groupId   String
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     ProjectGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([userId, groupId])
  @@index([groupId])
  @@index([userId])
}

/// Dynamic roles: created by admins at runtime, never hard-coded.
model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false) // seed roles (e.g. "admin") are protected from deletion
  /// deactivating a role stops it granting permissions to its members without
  /// deleting it — same pattern as User.isActive and Kpi/EvaluationArea.isActive
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  permissions RolePermission[]
  users       UserRole[]
  kpiMaps     KpiAssignment[]
}

/// Permission catalog: resource × action, seeded and extensible.
model Permission {
  id       String @id @default(uuid())
  resource String // e.g. "forms", "kpis", "dashboards"
  action   String // "view" | "edit" | "activate_deactivate" | "delete"

  roles RolePermission[]

  @@unique([resource, action])
}

enum PermissionScope {
  all
  department
  project_group
  own
  level
}

model RolePermission {
  roleId       String
  permissionId String
  /// Row-level scope narrowing this grant.
  scope        PermissionScope @default(all)
  /// Only meaningful when scope = "level" (dashboards:view): the PerformanceLevel
  /// ids this grant is restricted to. Empty/ignored for every other scope value.
  scopeValues  String[]        @default([])

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

/// Rotating refresh-token sessions (revocable server-side).
model Session {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String    @unique
  userAgent        String?
  ip               String?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  @@index([userId])
}

/// "Forgot password" reset links — same opaque-token/hash-at-rest shape as
/// Session's refresh tokens: only the SHA-256 hash is stored, the raw token
/// travels once in the emailed link and is never persisted.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ─────────────────────────── KPI Definition & Mapping ──────────────────────────

/// A named container for Evaluation Areas — no longer a flat metric itself
/// (no unit/target/direction/cadence: status comes from each area's raw
/// 0-5 score, not target-attainment; see EvaluationAreaEntry).
model Kpi {
  id        String   @id @default(uuid())
  name      String
  /// Relative importance of this KPI as a percentage (0-100). Purely
  /// informational at this layer — nothing currently rolls scores up
  /// through it; not required to sum to 100 across sibling KPIs.
  weight    Decimal? @db.Decimal(5, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  evaluationAreas EvaluationArea[]
  assignments     KpiAssignment[]
}

/// Dynamic mapping of a KPI to a role, department, or delivery stream.
model KpiAssignment {
  id             String      @id @default(uuid())
  kpiId          String
  kpi            Kpi         @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  roleId         String?
  role           Role?       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  departmentId   String?
  department     Department? @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  deliveryStream String? // free-form stream tag, e.g. "digital-channels"

  @@unique([kpiId, roleId, departmentId, deliveryStream])
  @@index([roleId])
  @@index([departmentId])
}

enum EvaluationAreaCadence {
  weekly
  monthly
  quarterly
  yearly
}

/// A named sub-category under a KPI (e.g. "Leadership & People Management",
/// matching the QA evaluation surveys this system is modeled on). Carries
/// its own cadence — different areas under the same KPI can be scored on
/// different rhythms.
model EvaluationArea {
  id        String                @id @default(uuid())
  kpiId     String
  kpi       Kpi                   @relation(fields: [kpiId], references: [id], onDelete: Cascade)
  name      String
  cadence   EvaluationAreaCadence
  isActive  Boolean               @default(true)
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  entries      EvaluationAreaEntry[]
  formMappings FormKpiMapping[]
  subCriteria  SubCriteria[]

  @@index([kpiId])
}

/// A named leaf under an Evaluation Area — pure taxonomy, no scoring/cadence
/// of its own (those stay at the EvaluationArea level; see FormKpiMapping and
/// EvaluationAreaEntry). Deleting one is a plain hard delete: unlike Kpi/
/// EvaluationArea, there's no recorded history under it to protect.
model SubCriteria {
  id               String         @id @default(uuid())
  evaluationAreaId String
  evaluationArea   EvaluationArea @relation(fields: [evaluationAreaId], references: [id], onDelete: Cascade)
  name             String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  formMappings FormKpiMapping[]

  @@index([evaluationAreaId])
}

/// Evaluation Area facts — a 0-5 score recorded against a specific evaluatee
/// (`person`) for a period, by a specific evaluator (`enteredBy`). One row
/// PER EVALUATOR per period (see the unique constraint below) — multiple
/// raters scoring the same person in the same period coexist as separate
/// entries rather than one overwriting another; the reader aggregates them.
model EvaluationAreaEntry {
  id               String          @id @default(uuid())
  evaluationAreaId String
  evaluationArea   EvaluationArea  @relation(fields: [evaluationAreaId], references: [id], onDelete: Cascade)
  personId         String
  person           User            @relation("EvaluationAreaEntryPerson", fields: [personId], references: [id])
  value            Decimal // 0-5
  periodStart      DateTime
  periodEnd        DateTime
  enteredById      String
  enteredBy        User            @relation("EvaluationAreaEntryEvaluator", fields: [enteredById], references: [id])
  note             String?
  /// Denormalized copy of the originating FormKpiMapping.reviewType at
  /// record time ('self' | 'peer' | 'manager' | '360') — kept even if the
  /// mapping's own reviewType later changes, so history doesn't shift under
  /// it. Null for entries recorded before this concept existed, or via the
  /// direct (non-forms) recording API. Left as a plain String rather than a
  /// Prisma enum: '360' isn't a valid Prisma enum member identifier without
  /// a `@map` indirection that would desync the DB-level name from the
  /// `ReviewType` union already enforced by every write path via
  /// `z.enum(REVIEW_TYPES)` in @pulse/contracts — not worth the added
  /// read/write translation layer for what Zod already guarantees.
  reviewType       String?
  /// Denormalized copy of the originating FormKpiMapping.anonymous at record
  /// time — whether enteredBy should be withheld from non-kpis:manage
  /// readers. Snapshotted for the same reason as reviewType: changing the
  /// mapping's setting later shouldn't retroactively reveal/hide history.
  anonymous        Boolean         @default(false)
  /// Free-text snapshot of the mapping's contextFieldKey answer at record
  /// time (e.g. "Level: Expert"), when the mapping defines one.
  context          String?
  /// Free-text snapshot of the mapping's commentFieldKey answer at record
  /// time, when the mapping defines one.
  comment          String?
  submissionId     String?
  submission       FormSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  /// Which FormKpiMapping produced this entry — null for entries recorded
  /// before this concept existed, or via the direct (non-forms) recording
  /// API. Part of the uniqueness key below so two mappings sharing the same
  /// Evaluation Area (distinguished only by subCriteriaId — see
  /// FormKpiMapping) each keep their own entry instead of the second
  /// mapping's upsert silently overwriting the first's score. SetNull on
  /// delete so removing a mapping doesn't destroy its scoring history.
  mappingId        String?
  mapping          FormKpiMapping? @relation(fields: [mappingId], references: [id], onDelete: SetNull)
  createdAt        DateTime        @default(now())

  @@unique([evaluationAreaId, personId, periodStart, periodEnd, enteredById, mappingId], map: "EvaluationAreaEntry_area_person_period_evaluator_mapping_key")
  @@index([evaluationAreaId, periodStart])
  @@index([personId])
  @@index([enteredById])
  @@index([submissionId])
  @@index([mappingId])
}

// ─────────────────────────── Schema-driven Form Builder ────────────────────────

enum FormStatus {
  draft
  published
  archived
}

model Form {
  id          String     @id @default(uuid())
  slug        String     @unique
  status      FormStatus @default(draft)
  /// FormSettings JSON: acceptingResponses, opensAt/closesAt, oneResponsePerUser…
  settings    Json?
  /// Non-null enables the anonymous public fill link (/f?token=…)
  publicToken String?    @unique
  /// When true, only the creator, a FormCollaborator, or a forms:manage holder
  /// may view/fill/manage this form via the portal — independent of the
  /// anonymous public link above, which stays open-to-anyone once enabled.
  restricted  Boolean    @default(false)
  /// Simple free-text tag for the forms list filter — not a nested hierarchy.
  folder      String?
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  versions      FormVersion[]
  fileUploads   FormFileUpload[]
  assets        FormAsset[]
  collaborators FormCollaborator[]
  kpiMappings   FormKpiMapping[]

  @@index([status])
  @@index([createdById])
  @@index([folder])
}

/// A specific person granted access to one restricted form, bypassing the
/// org-wide forms:read/forms:write RBAC requirement for that form only.
model FormCollaborator {
  id               String   @id @default(uuid())
  formId           String
  form             Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation("FormCollaboratorUser", fields: [userId], references: [id], onDelete: Cascade)
  /// false = can view/fill only; true = co-owner (can also edit/publish/manage this form)
  canManage        Boolean  @default(false)
  /// Tier between fill-only and co-owner: can see this form's responses/summary/exports
  /// without editing the form itself. Implied by canManage — checked independently.
  canViewResponses Boolean  @default(false)
  addedById        String?
  addedBy          User?    @relation("FormCollaboratorAddedBy", fields: [addedById], references: [id])
  createdAt        DateTime @default(now())

  @@unique([formId, userId])
  @@index([userId])
}

/// Bridges Forms and KPIs: on every submission to `formId`, the answer at
/// one of `evaluateeFieldKeys` (each a 'person' field — the evaluatee) and
/// the answer at `scoreFieldKey` (a rating/nps/slider field, normalized to
/// 0-5) are upserted as an EvaluationAreaEntry against `evaluationAreaId`.
/// See SubmissionsService.
model FormKpiMapping {
  id                 String                @id @default(uuid())
  formId             String
  form               Form                  @relation(fields: [formId], references: [id], onDelete: Cascade)
  evaluationAreaId   String
  evaluationArea     EvaluationArea        @relation(fields: [evaluationAreaId], references: [id], onDelete: Cascade)
  /// Candidate fields that could name the evaluatee, tried in order,
  /// first-answered-wins — e.g. a form with several per-project "Tester"
  /// fields where only one is filled in per submission. An empty array means
  /// self-assessment: the submitter scores themselves. If candidates are
  /// configured but none were answered, no evaluatee resolves (the score
  /// does NOT fall back to self) — see SubmissionsService.applyOneMapping.
  evaluateeFieldKeys String[]              @default([])
  scoreFieldKey      String
  /// Who this mapping's scores come from, relative to the evaluatee —
  /// 'self' | 'peer' | 'manager' | '360'. Drives the dashboard's per-type
  /// breakdown and is copied onto every entry it produces.
  reviewType         String                @default("peer")
  /// When true, the evaluator's identity is withheld from anyone without
  /// kpis:manage when reading entries this mapping produced — standard
  /// practice for honest peer/360 feedback.
  anonymous          Boolean               @default(false)
  /// Optional extra form field (any type) whose answer is snapshotted onto
  /// each entry as free-text context, e.g. the evaluatee's level.
  contextFieldKey    String?
  /// Optional extra form field (normally long_text) snapshotted onto each
  /// entry as its qualitative comment.
  commentFieldKey    String?
  /// Purely descriptive tag — narrows which Sub-Criteria under the mapped
  /// Evaluation Area this question is meant for. Never read by scoring
  /// (SubmissionsService/score-resolution still resolve off evaluationAreaId
  /// alone); SetNull on delete so removing a Sub-Criteria just clears the
  /// tag instead of destroying the mapping.
  subCriteriaId      String?
  subCriteria        SubCriteria?          @relation(fields: [subCriteriaId], references: [id], onDelete: SetNull)
  entries            EvaluationAreaEntry[]
  createdAt          DateTime              @default(now())

  /// Two mappings CAN now share an Evaluation Area as long as their
  /// subCriteriaId differs (or one is null) — see EvaluationAreaEntry.mappingId
  /// for how their scores stay distinct instead of one overwriting the other.
  @@unique([formId, evaluationAreaId, subCriteriaId])
  @@index([evaluationAreaId])
  @@index([subCriteriaId])
}

/// Immutable versions: editing a published form creates a new version, so old
/// submissions always validate against the schema they were created with.
model FormVersion {
  id         String   @id @default(uuid())
  formId     String
  form       Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  version    Int
  /// FormDefinition JSON (validated against @pulse/contracts formDefinitionSchema).
  definition Json
  createdAt  DateTime @default(now())

  submissions FormSubmission[]

  @@unique([formId, version])
}

model FormSubmission {
  id                    String      @id @default(uuid())
  formVersionId         String
  formVersion           FormVersion @relation(fields: [formVersionId], references: [id], onDelete: Cascade)
  submittedById         String?
  submittedBy           User?       @relation(fields: [submittedById], references: [id])
  /// Random id from a cookie set on first visit — the only "identity" an anonymous
  /// public-link respondent has, used to enforce oneResponsePerUser without an account.
  respondentFingerprint String?
  /// Self-reported name/email, collected on the pre-form gate screen when the
  /// form's `requireRespondentInfo` setting is on — null for forms without
  /// the gate, and always null for authenticated submissions (submittedById
  /// already identifies those). Email is checked against EmailDomain at
  /// submit time; not re-validated here since domains can change later.
  respondentName        String?
  respondentEmail       String?
  /// fieldKey → answer. GIN-indexed for filtering (index added in raw migration).
  answers               Json
  /// QuizScore JSON ({earnedPoints, totalPoints, percent, passed}), computed once at
  /// submit time against the version's definition — null for non-quiz forms.
  score                 Json?
  /// Set at submit time only when the form's `allowRespondentEdit` setting is on —
  /// lets the respondent revise this submission via PATCH .../submissions/:editToken.
  editToken             String?     @unique
  createdAt             DateTime    @default(now())

  fileUploads           FormFileUpload[]
  evaluationAreaEntries EvaluationAreaEntry[]

  @@index([formVersionId, createdAt])
  @@index([submittedById])
  @@index([respondentFingerprint])
}

/// Uploaded files for `file`-type fields. Stored as a DB blob (not object
/// storage) — the deliberate tradeoff for an internal tool with a per-file
/// size cap (see formFieldSchema's `file` variant, maxSizeMb) over standing
/// up an external bucket. Uploaded ahead of the submission (the field
/// answer is this row's id); `submissionId` is attached once the containing
/// submission is created, and orphaned pre-submit uploads are swept below.
model FormFileUpload {
  id           String          @id @default(uuid())
  formId       String
  form         Form            @relation(fields: [formId], references: [id], onDelete: Cascade)
  fieldKey     String
  filename     String
  mimeType     String
  sizeBytes    Int
  data         Bytes
  uploadedById String?
  uploadedBy   User?           @relation(fields: [uploadedById], references: [id])
  submissionId String?
  submission   FormSubmission? @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  createdAt    DateTime        @default(now())

  @@index([formId])
  @@index([submissionId])
}

/// Builder-uploaded design assets (option images, question/page media, theme
/// background & logo) — distinct from FormFileUpload, which holds RESPONDENT
/// answers. Uploaded while a form is still a draft (no Form row exists yet),
/// so formId starts null and is claimed once the definition referencing it is
/// published — same orphan-then-claim pattern as FormFileUpload/submissionId.
/// Same DB-blob tradeoff, served publicly since they're decorative, not
/// sensitive (see AssetsService).
model FormAsset {
  id          String   @id @default(uuid())
  formId      String?
  form        Form?    @relation(fields: [formId], references: [id], onDelete: Cascade)
  filename    String
  mimeType    String
  sizeBytes   Int
  data        Bytes
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([formId])
}

// ─────────────────────────── Governance ────────────────────────────────────────

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String // "role.created", "role.permissions.updated", "submissions.exported" …
  entity    String
  entityId  String?
  detail    Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
  @@index([actorId])
}

/// Branding configuration for the landing page/portal (logo URL, strings).
model BrandSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// ─────────────────────────── Scoring Configuration ─────────────────────────────

/// Names a band of the 0-5 EvaluationAreaEntry score range (e.g. "Outstanding"
/// for 4.0-5.0) — the Configuration page's Performance Levels tab. Purely a
/// labeling/display concern: nothing currently reads this to band a person's
/// finalScore (see apps/web/lib/kpi-status.ts, which still uses its own fixed
/// thresholds) until that's wired up.
model PerformanceLevel {
  id        String   @id @default(uuid())
  label     String
  minScore  Decimal // 0-5
  maxScore  Decimal // 0-5
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Names a single point on the 0-5 EvaluationAreaEntry score scale (e.g.
/// "Outstanding" for 5) — the Configuration page's Score Labels tab.
/// Separate from PerformanceLevel (which names a range): purely a
/// labeling/display concern, not read anywhere else yet.
model ScoreLabel {
  id        String   @id @default(uuid())
  label     String
  score     Int // 0-5, whole number
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// A named job title — the Configuration page's Job Titles tab. Plain
/// label, no relation to User yet (not currently assignable to anyone).
model JobTitle {
  id        String   @id @default(uuid())
  label     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

/// Global, admin-managed subset of Forms whose submissions feed the
/// dashboard (raw submissions, the legacy blended status score, and the
/// activity trend — NOT the measurement-gaps audit, which deliberately
/// always reflects every form regardless of this scope). Single row, id
/// fixed to 1. `formIds` empty = unrestricted (every form counts), the
/// default until an admin configures it via PUT /v1/kpis/dashboard-form-scope.
model DashboardFormScope {
  id        Int      @id @default(1)
  formIds   String[] @default([])
  updatedAt DateTime @updatedAt
}
