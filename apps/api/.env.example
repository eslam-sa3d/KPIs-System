# Copy to .env and fill in local values. Validated at startup by src/infra/env.ts
# — anything required but missing there fails fast with a clear error instead
# of surfacing later as a broken request.

# Required
DATABASE_URL="postgresql://pulse:pulse@localhost:5432/pulse_kpi"
JWT_SECRET="local-dev-secret-change-me"

# Optional — defaults shown are what src/infra/env.ts falls back to
NODE_ENV="development"
PORT=4000
REDIS_URL="redis://localhost:6379"
CORS_ORIGINS="http://localhost:3000"
WEB_URL="http://localhost:3000"
# 'strict' | 'lax' | 'none' — see auth.controller.ts for when 'none' is needed
REFRESH_COOKIE_SAMESITE="strict"

# Optional integrations — safe to leave unset in dev; each degrades gracefully
# (logs instead of sending an email, skips CAPTCHA verification)
MAILERSEND_API_KEY=
MAIL_FROM_EMAIL="no-reply@pulse.local"
MAIL_FROM_NAME="pulse"
TURNSTILE_SECRET_KEY=

# Only used by prisma/seed.ts (runs on every boot in production — see
# render.yaml). Required in production; falls back to a known dev-only
# default anywhere else.
SEED_ADMIN_EMAIL="admin@pulse.local"
SEED_ADMIN_PASSWORD=
